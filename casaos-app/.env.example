# Auto RPS & OBE AI - Casa OS Configuration
# Copy file ini ke .env lalu sesuaikan

# Port untuk backend API (default: 9810)
AUTO_RPS_BACKEND_PORT=9810

# Port untuk frontend (default: 9811)
AUTO_RPS_FRONTEND_PORT=9811

# URL Ollama (default: http://host.docker.internal:11434)
OLLAMA_URL=http://host.docker.internal:11434

# Model AI yang digunakan
OLLAMA_MODEL=llama3.1:8b
